{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paloframework.org/schemas/palo-source-registry.schema.json",
  "title": "PALO Source Registry",
  "type": "object",
  "required": ["format", "schemaVersion", "status", "updatedAt", "disclaimer", "sources"],
  "properties": {
    "format": { "const": "palo-source-registry" },
    "schemaVersion": { "const": "1.0.0" },
    "status": { "const": "educational-non-production" },
    "updatedAt": { "type": "string", "format": "date" },
    "disclaimer": { "type": "string", "minLength": 20 },
    "sources": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["sourceId", "title", "url", "sourceType", "publisher", "checkedAt", "freshness", "authorityStatus", "usageNote"],
        "properties": {
          "sourceId": { "type": "string", "pattern": "^src-[a-z0-9-]+$" },
          "title": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" },
          "sourceType": { "enum": ["official", "standard", "organizational", "research", "monitoring-signal"] },
          "publisher": { "type": "string", "minLength": 1 },
          "checkedAt": { "type": "string", "format": "date-time" },
          "freshness": { "type": "object", "required": ["status", "reviewIntervalDays", "nextReviewAt"], "properties": { "status": { "enum": ["current", "review-due", "stale", "superseded", "unknown"] }, "reviewIntervalDays": { "type": "integer", "minimum": 1 }, "nextReviewAt": { "type": "string", "format": "date-time" } }, "additionalProperties": false },
          "authorityStatus": { "enum": ["authoritative-primary", "authoritative-standard", "informative", "non-authoritative-monitoring-signal"] },
          "usageNote": { "type": "string", "minLength": 10 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
