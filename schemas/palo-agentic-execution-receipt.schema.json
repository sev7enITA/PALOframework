{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paloframework.org/schemas/palo-agentic-execution-receipt.schema.json",
  "title": "PALO Trusted Execution Receipt",
  "description": "Developer-preview signed receipt generated by the trusted executor rather than by the calling agent.",
  "type": "object",
  "required": ["format", "schemaVersion", "executionId", "capabilityId", "claimId", "claimDigest", "executorId", "status", "startedAt", "completedAt", "preStateDigest", "requestDigest", "resultDigest", "keyId", "algorithm", "signature"],
  "properties": {
    "format": { "const": "palo-agentic-execution-receipt" },
    "schemaVersion": { "const": "1.0.0" },
    "executionId": { "type": "string", "pattern": "^execution-[a-f0-9-]{36}$" },
    "capabilityId": { "type": "string", "pattern": "^capability-[a-f0-9-]{36}$" },
    "claimId": { "type": "string", "pattern": "^claim-[a-f0-9-]{36}$" },
    "claimDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "executorId": { "type": "string", "pattern": "^executor-[a-zA-Z0-9][a-zA-Z0-9._-]{2,100}$" },
    "status": { "enum": ["succeeded", "failed", "unknown"] },
    "startedAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": "string", "format": "date-time" },
    "preStateDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "resourceVersion": { "type": "string", "maxLength": 500 },
    "requestDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "resultDigest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "error": { "type": "string", "maxLength": 4000 },
    "keyId": { "type": "string", "pattern": "^key-[a-zA-Z0-9._-]{3,100}$" },
    "algorithm": { "const": "HMAC-SHA256" },
    "signature": { "type": "string", "pattern": "^hmac-sha256:[a-f0-9]{64}$" }
  },
  "additionalProperties": false
}
