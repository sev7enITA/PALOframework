{
	email {$ACME_EMAIL}
}

{$PALO_DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	log {
		output stdout
		format json
	}

	handle /mcp-health {
		rewrite * /health
		reverse_proxy palo-mcp:8788
	}

	handle /mcp {
		reverse_proxy palo-mcp:8788
	}

	@blockedGateway {
		path /gateway/v1/agents/* /gateway/v1/policies/* /gateway/v1/approvals /gateway/v1/approvals/resolve /gateway/v1/evidence
	}
	handle @blockedGateway {
		respond "Not found" 404
	}

	@publicGateway {
		path /gateway/health /gateway/v1/registry /gateway/v1/actions/verify /gateway/v1/approvals/* /gateway/v1/evidence/verify-ledger
	}
	handle @publicGateway {
		uri strip_prefix /gateway
		reverse_proxy palo-gateway:8787
	}

	handle {
		respond "Not found" 404
	}
}
